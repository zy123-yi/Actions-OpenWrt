# =========================================================
# 1. 基础架构与磁盘设置 (i7-5500U x86_64 专用)
# =========================================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_VMDK_IMAGES=y
CONFIG_TARGET_KERNEL_PARTSIZE=500
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# =========================================================
# 2. 防火墙与内核加速 (FW4/Nftables + BBR)
# =========================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_libnftnl=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y

# 核心加速：对抗 42% 丢包的神药
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_tcp_congestion_control="bbr"
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_irqbalance=y

# TProxy 核心组件
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-nf-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y

# =========================================================
# 3. 核心代理套件 (PassWall + SSR Plus+ 融合)
# =========================================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_I18N_zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus=y

# SSR Plus+ 作为备选分流工具
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_I18N_zh-cn=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client=y

# =========================================================
# 4. 新增：WireGuard & Cloudflare Zero Trust 支持
# =========================================================
# 内核驱动与协议支持
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-i18n-wireguard-zh-cn=y
CONFIG_PACKAGE_luci-proto-wireguard=y

# Cloudflare Tunnel (TCP 模式保底，对抗 UDP 阻断)
CONFIG_PACKAGE_cloudflared=y

# 加密与证书必备 (防止 Zero Trust 握手失败)
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_openssl-util=y

# =========================================================
# 5. DNS 与分流链条 (Unbound + MosDNS + AdGuard)
# =========================================================
CONFIG_PACKAGE_luci-app-unbound=y
CONFIG_PACKAGE_unbound-daemon=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_chinadns-ng=y

# =========================================================
# 6. Sing-Box 进阶特性 (1G 带宽稳定核心)
# =========================================================
CONFIG_SING_BOX_BUILD_QUIC=y
CONFIG_SING_BOX_BUILD_UTLS=y
CONFIG_SING_BOX_BUILD_WIREGUARD=y
CONFIG_SING_BOX_BUILD_HYSTERIA=y
CONFIG_SING_BOX_BUILD_GVISOR=y

# =========================================================
# 7. 系统诊断工具 (排查限速与丢包)
# =========================================================
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_lm-sensors=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_luci-app-ttyd=y

# =========================================================
# 8. 新增：udp2raw 隧道支持 (对抗 UDP 丢包限速)
# =========================================================
# 核心程序 (Bin)
CONFIG_PACKAGE_udp2raw=y

# LuCI 界面 (必须勾选，否则服务菜单不显示)
CONFIG_PACKAGE_luci-app-udp2raw=y
CONFIG_PACKAGE_luci-i18n-udp2raw-zh-cn=y

# 依赖补充：确保 C++ 运行库完整 (防止手动运行报错)
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_librt=y

# 兼容性补充：FW4 环境下模拟 iptables 行为 (udp2raw -a 模式必备)
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

