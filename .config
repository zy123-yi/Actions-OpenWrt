# =========================================================
# 1. 基础架构与内核核心 (eBPF & BTF 必须置顶)
# =========================================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 核心 eBPF 开关 (daed 运行的灵魂)
CONFIG_DEBUG_INFO_BTF=y
CONFIG_BPF_TOOLCHAIN_HOST=y
CONFIG_KERNEL_BPF_EVENTS=y
CONFIG_KERNEL_DEBUG_INFO_BTF=y
CONFIG_KERNEL_CGROUP_BPF=y
CONFIG_KERNEL_BPF_STREAM_PARSER=y

# 磁盘与镜像设置 (i7-5500U 专用)
CONFIG_VMDK_IMAGES=y
CONFIG_TARGET_KERNEL_PARTSIZE=500
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# =========================================================
# 2. 防火墙与内核加速 (FW4/Nftables + BBR)
# =========================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_libnftnl=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_kmod-nfnetlink-queue=y
# 顺便补全 sing-box 常见的其他内核依赖
CONFIG_PACKAGE_kmod-nft-address=y

# 核心加速：对抗丢包神药
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_tcp_congestion_control="bbr"
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_irqbalance=y

# TProxy 核心组件 (PassWall 运行基础)
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-nf-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# =========================================================
# 3. daed (eBPF) 高性能代理套件 (新增修正项)
# =========================================================
# 核心应用与界面
CONFIG_PACKAGE_daed=y
CONFIG_PACKAGE_luci-app-daed=y
CONFIG_PACKAGE_luci-i18n-daed-zh-cn=y
CONFIG_PACKAGE_luci-app-daed_I18N_zh-cn=y

# eBPF 核心依赖 (6.12 内核满血运行必备)
CONFIG_PACKAGE_kmod-google-bpf=y
CONFIG_PACKAGE_kmod-ebpf-conntrack=y
CONFIG_PACKAGE_kmod-xdp-sockets-diag=y
CONFIG_PACKAGE_kmod-net-cls-bpf=y
CONFIG_PACKAGE_libbpf=y
CONFIG_PACKAGE_bpftool=y

# 辅助增强
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-bpf=y

# =========================================================
# 4. 核心代理套件 (PassWall 保留)
# =========================================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_I18N_zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus=y

# =========================================================
# 5. DNS 与分流链条 (Unbound + MosDNS + AdGuard)
# =========================================================
CONFIG_PACKAGE_luci-app-unbound=y
CONFIG_PACKAGE_unbound-daemon=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_chinadns-ng=y

# =========================================================
# 6. Sing-Box 进阶特性 (1G 带宽稳定核心)
# =========================================================
CONFIG_SING_BOX_BUILD_QUIC=y
CONFIG_SING_BOX_BUILD_UTLS=y
CONFIG_SING_BOX_BUILD_WIREGUARD=y
CONFIG_SING_BOX_BUILD_HYSTERIA=y
CONFIG_SING_BOX_BUILD_GVISOR=y

# =========================================================
# 7. 系统诊断工具 (排查限速与丢包)
# =========================================================
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_lm-sensors=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
# 启用 LuCI 核心集合 (包含 uhttpd, uci 等)
CONFIG_PACKAGE_luci=y

# 启用简体中文语言包 (2026 年版本通常为 zh-cn)
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG luci-i18n-passwall-zh-cn=y
CONFIG luci-i18n-mosdns-zh-cn=y

# 网络加速 Turbo ACC
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_DNSCACHE=n # 既然用了 MosDNS，这里建议关闭
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_SHORTCUT_FE=y

# KMS 激活服务
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_vlmcsd=y
